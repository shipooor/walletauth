{
  "name": "@shipooor/walletauth",
  "version": "0.1.1",
  "description": "Your wallet is your API key. Agent-native auth for APIs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wallet",
    "auth",
    "authentication",
    "signature",
    "jwt",
    "agent",
    "ai-agent",
    "web3",
    "evm",
    "solana",
    "ed25519",
    "secp256k1"
  ],
  "author": {
    "name": "shipooor",
    "url": "https://shipooor.xyz"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shipooor/walletauth.git"
  },
  "homepage": "https://walletauth.shipooor.xyz",
  "bugs": {
    "url": "https://github.com/shipooor/walletauth/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
